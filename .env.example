# Supabase Configuration for Global Leaderboard
# Instructions:
# 1. Create a Supabase project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the "Project URL" and "anon public" key
# 4. Run the SQL commands from the setup guide to create the leaderboard table
# 5. Copy this file to .env and fill in your values

# Your Supabase Project URL (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url_here

# Your Supabase Anon/Public Key (safe to expose client-side)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
